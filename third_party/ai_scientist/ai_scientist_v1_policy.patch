+    numeric_rule = contract.get("prose_numeric_policy", "")
+
+    coder.run(f"""Fill the title and abstract in latex/template.tex for the research program {idea['Title']}.
+Use only the evidence below. The manuscript describes a synthetic mechanism experiment, not causal estimates for real ministries.
