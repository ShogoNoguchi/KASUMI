+
+<verified_evidence>
+{evidence}
+</verified_evidence>
+
+Guidance: {section_tips['Abstract']}
+Use SEARCH/REPLACE edits only on latex/template.tex.""")
+    coder.run(
+        "Criticize and refine only the title and abstract. Preserve the synthetic claim boundary, "
+        "remove unsupported numerical prose, and leave no placeholders."
+    )
+
+    for section in section_order:
