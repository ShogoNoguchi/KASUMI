+        raise ValueError(f"Protected template idea lacks run_{run_num}")
+    path = osp.join(folder_name, "candidate_policy.json")
+    tmp = f"{path}.tmp.{os.getpid()}"
+    with open(tmp, "w", encoding="utf-8") as handle:
+        json.dump(intervention["Policy"], handle, ensure_ascii=False, indent=2, sort_keys=True)
+        handle.write("\n")
+        handle.flush()
+        os.fsync(handle.fileno())
+    os.replace(tmp, path)
+    with open(osp.join(folder_name, "notes.txt"), "a", encoding="utf-8") as notes:
