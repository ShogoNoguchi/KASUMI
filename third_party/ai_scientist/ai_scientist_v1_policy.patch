+def _exact_policy_prompt(idea, run_num, baseline_results, problem_context, error_message=None):
+    intervention = _intervention_for_run(idea, run_num)
+    if intervention is None:
+        return None
+    policy_json = json.dumps(intervention["Policy"], ensure_ascii=False, indent=2)
+    error_block = "" if not error_message else f"\nThe previous attempt failed with this diagnostic; correct only the JSON transcription error and preserve the exact mapping:\n{error_message}\n"
+    return f"""Implement the prevalidated policy mapping for run_{run_num}. Edit only candidate_policy.json. Replace the entire file with exactly this strict JSON object; do not alter any value, add any field, or edit Python:
